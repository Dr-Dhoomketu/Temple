# ─── Shri Ram Mandir — Environment Variables ───────────────────────────────
# Copy this file to .env for local development.
# On Vercel: add these in Project Settings → Environment Variables.
# NEVER commit .env to git.

# ── Gmail (for donation thank-you emails) ──────────────────────────────────
# Your full Gmail address
GMAIL_USER=yourname@gmail.com

# Gmail App Password (NOT your regular password).
# Steps:
#   1. Enable 2-Step Verification at myaccount.google.com/security
#   2. Go to myaccount.google.com/apppasswords
#   3. Create a new App Password (select "Mail")
#   4. Paste the 16-character code below (spaces are fine)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── Email server port (local development only, ignored on Vercel) ───────────
EMAIL_SERVER_PORT=3001

# ── Supabase (donation database) ───────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
